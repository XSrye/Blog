---
import { Icon } from "astro-icon/components";
---

<!-- footer (Vermilion style) -->
<footer class="flex justify-center py-6 text-[var(--text-color-70)] max-w-[var(--header-width)] mx-auto w-full" style="font-size: 0.85rem;">
    <a href="/rss.xml" target="_self" title="RSS"><Icon name="simple-icons:rss" class="inline-block w-4 h-4" /></a>
</footer>

<style>
    footer { font-family: "EB Garamond", cursive !important; border-top: 1px solid var(--hairline); }
    footer a { color: inherit; text-decoration: none; transition: color 0.2s ease; }
    footer a:hover { color: var(--link-color); }
</style>
