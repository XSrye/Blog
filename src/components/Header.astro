---
import "@styles/global.css"
import { Icon } from "astro-icon/components"
import { profileConfig, siteConfig } from "@/config"
import ThemeIcon from "./control/ThemeIcon.astro"
import { baseUrl } from "@utils/url-utils"

import { i18n } from "astro:config/client";
import i18nit from '@i18n/translation'
import { getRelativeLocaleUrl } from '@utils/url-utils';

const currentLang = Astro.currentLocale || i18n!.defaultLocale;
const t = i18nit(currentLang);
const showLanguageSwitcher = (i18n?.locales?.length ?? 0) > 1;


// 获取当前页面在不同语言下的路径
const getLocalePath = (path: string, targetLocale: string) => {
  const currentPath = Astro.url.pathname;
  const defaultLocale = i18n?.defaultLocale || "zh-cn";
  
  let basePath = currentPath;
  if (currentLang && currentLang !== defaultLocale) {
    basePath = currentPath.replace(`/${currentLang}`, "") || "/";
  }
  
  if (targetLocale && targetLocale !== defaultLocale) {
    return `/${targetLocale}${basePath}`;
  }
  
  return basePath;
};

const indexPage = getRelativeLocaleUrl(currentLang, "/");
const essayPage = getRelativeLocaleUrl(currentLang, "/essay/");
const talkPage = getRelativeLocaleUrl(currentLang, "/talk/");
const musicPage = getRelativeLocaleUrl(currentLang, "/music/");
---

<!-- header (Vermilion style) -->
<div id="main-header">
<div class="header-inner">
    <!-- Top row: title + tools -->
    <div class="title-tools-row">
        <div class="title">
            <h1><a href={ indexPage }>{ siteConfig.title }</a></h1>
            <a href="/rss.xml" target="_self" title="RSS" class="rss-icon"><Icon name="simple-icons:rss" class="inline-block w-4 h-4" /></a>
        </div>
        <div class="header-tools">
            <button id="search-button" class="tool-btn" aria-label="Search">
                <Icon name="fa6-solid:magnifying-glass" class="w-4 h-4" />
            </button>
            <ThemeIcon class="tool-btn"/>
            {showLanguageSwitcher && <div class="relative">
                <button id="language-button" class="tool-btn" aria-label="Language">
                    <Icon name="fa6-solid:globe" class="w-4 h-4" />
                </button>
                <div id="language-menu" class="hidden absolute right-0 mt-2 w-30 bg-[var(--bg-color)] border border-[var(--hairline)] rounded z-50 shadow-lg">
                    <div class="py-1 text-right">
                        <a href={getLocalePath("/", "zh-cn")} class="block mx-2 my-1 p-2 text-sm rounded hover:bg-[var(--button-hover-color)]">
                            {currentLang === "zh-cn" ? <Icon name="fa6-solid:circle" class="w-2 h-2 inline mr-2" /> : ""}
                            简体中文
                        </a>
                        <a href={getLocalePath("/", "en")} class="block mx-2 my-1 p-2 text-sm rounded hover:bg-[var(--button-hover-color)]">
                            {currentLang === "en" ? <Icon name="fa6-solid:circle" class="w-2 h-2 inline mr-2" /> : ""}
                            English
                        </a>
                    </div>
                </div>
            </div>}
            <!-- Mobile hamburger -->
            <button id="mobile-menu-button" class="tool-btn md:hidden" aria-label="Menu">
                <Icon name="fa6-solid:align-justify" class="w-5 h-5" />
            </button>
        </div>
    </div>
    <!-- Bottom row: navigation tags -->
    <nav class="desktop-nav">
        <a href={ essayPage }>{t("header.essay")}</a>
        <a href={ talkPage }>{t("header.talk")}</a>
        <a href={ musicPage }>{t("header.music")}</a>
    </nav>
</div>
</div>

<!-- Mobile Menu -->
<div id="mobile-menu-container" class="fixed inset-0 z-[100] hidden">
    <div id="mobile-menu-overlay" class="absolute inset-0 bg-black/60 backdrop-blur-sm opacity-0 transition-opacity duration-300 ease-in-out"></div>
    
    <div id="mobile-menu-drawer" class="absolute top-0 left-0 bottom-0 w-[70%] max-w-[300px] bg-[var(--bg-color)] shadow-2xl transform -translate-x-full transition-transform duration-300 ease-in-out flex flex-col">
        
        <div class="flex items-center justify-between p-5 border-b border-[var(--hairline)]">
            <span class="text-xl font-bold" style="font-family: 'EB Garamond', cursive;">{ siteConfig.title }</span>
            <button id="mobile-menu-close" class="w-10 h-10 flex items-center justify-center rounded-lg hover:bg-[var(--button-hover-color)] transition-colors">
                <Icon name="fa6-solid:xmark" class="w-5 h-5" />
            </button>
        </div>

        <nav class="flex flex-col py-4 px-2">
            <a href={ essayPage } class="flex items-center gap-3 px-4 py-3 rounded-lg hover:bg-[var(--button-hover-color)] transition-colors">
                <Icon name="fa6-solid:pen-nib" class="w-4 h-4 opacity-70" />
                <span>{t("header.essay")}</span>
            </a>
            <a href={ talkPage } class="flex items-center gap-3 px-4 py-3 rounded-lg hover:bg-[var(--button-hover-color)] transition-colors">
                <Icon name="fa6-solid:comments" class="w-4 h-4 opacity-70" />
                <span>{t("header.talk")}</span>
            </a>
            <a href={ musicPage } class="flex items-center gap-3 px-4 py-3 rounded-lg hover:bg-[var(--button-hover-color)] transition-colors">
                <Icon name="fa6-solid:music" class="w-4 h-4 opacity-70" />
                <span>{t("header.music")}</span>
            </a>
        </nav>

        <div class="mt-auto p-5 border-t border-[var(--hairline)] text-sm opacity-70">
            &copy; {profileConfig.startYear} &ndash; {new Date().getFullYear()} {profileConfig.name}.
        </div>
    </div>
</div>

<style is:global>
.header-inner {
  max-width: var(--header-width);
  margin: 0 auto;
  padding: 0.5rem 0;
}
.title-tools-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
}
.title {
  display: flex;
  align-items: center;
  gap: 0.5em;
}
.title h1 {
  font-size: 1.5rem;
  font-weight: 600;
  letter-spacing: 0.04em;
  color: var(--text-color);
  display: inline-block;
  font-family: "EB Garamond", cursive;
}
.title h1 a, .title h1 a:visited {
  color: inherit;
  text-decoration: none;
}
.title h1::after {
  content: "";
  display: inline-block;
  width: 0.5em;
  height: 0.5em;
  margin-left: 0.4em;
  background: var(--link-color);
  border-radius: 1px;
  vertical-align: baseline;
}
.rss-icon {
  color: var(--text-color-70);
  transition: color 0.2s ease;
  line-height: 1;
}
.rss-icon:hover {
  color: var(--link-color);
}
.desktop-nav {
  display: flex;
  gap: 1.2em;
  padding: 0.4rem 0 0.2rem;
}
.desktop-nav a {
  font-size: 0.9rem;
  letter-spacing: 0.05em;
  color: var(--text-color-70);
  text-decoration: none;
  transition: color 0.2s ease;
}
.desktop-nav a:hover {
  color: var(--link-color);
}
.header-tools {
  display: flex;
  align-items: center;
  gap: 0.4rem;
}
.tool-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 2.25rem;
  height: 2.25rem;
  color: var(--text-color-70);
  border-radius: 4px;
  cursor: pointer;
  transition: color 0.2s ease, background-color 0.2s ease;
  background: transparent;
  border: none;
}
.tool-btn:hover {
  color: var(--link-color);
  background-color: var(--button-hover-color);
}
@media (max-width: 775px) {
  .desktop-nav { display: none; }
}
</style>

<script>
function initMobileNav() {
  const menuButton = document.getElementById('mobile-menu-button');
  const closeButton = document.getElementById('mobile-menu-close');
  const container = document.getElementById('mobile-menu-container');
  const overlay = document.getElementById('mobile-menu-overlay');
  const drawer = document.getElementById('mobile-menu-drawer');

  if (!menuButton || !container) return;

  function openMenu() {
    container.classList.remove('hidden');
    requestAnimationFrame(() => {
      overlay.classList.add('opacity-100');
      drawer.classList.remove('-translate-x-full');
    });
    document.body.style.overflow = 'hidden';
  }

  function closeMenu() {
    overlay.classList.remove('opacity-100');
    drawer.classList.add('-translate-x-full');
    setTimeout(() => {
      container.classList.add('hidden');
      document.body.style.overflow = '';
    }, 300);
  }

  menuButton.addEventListener('click', openMenu);
  closeButton?.addEventListener('click', closeMenu);
  overlay?.addEventListener('click', closeMenu);

  drawer?.querySelectorAll('a').forEach(link => {
    link.addEventListener('click', closeMenu);
  });
}

document.addEventListener('DOMContentLoaded', initMobileNav);
document.addEventListener('astro:page-load', initMobileNav);
</script>
<script>
function initLanguageMenu() {
  const languageButton = document.getElementById('language-button');
  const languageMenu = document.getElementById('language-menu');

  if (!languageButton || languageButton.dataset.bound === 'true') return;
  languageButton.dataset.bound = 'true';

  languageButton.addEventListener('click', (e) => {
    e.stopPropagation();
    languageMenu.classList.toggle('hidden');
  });

  document.addEventListener('click', (event) => {
    const target = event.target;
    if (
      target instanceof Node &&
      languageButton &&
      languageMenu &&
      !languageButton.contains(target) &&
      !languageMenu.contains(target)
    ) {
      languageMenu.classList.add('hidden');
    }
  });
}
document.addEventListener('astro:page-load', initLanguageMenu);
document.addEventListener('astro:after-swap', initLanguageMenu);
</script>

{import.meta.env.PROD && 
<script is:inline define:vars={{ scriptUrl: baseUrl('/pagefind/pagefind.js') }}>
async function loadAndSearch() {
  if (window.pagefind && typeof window.pagefind.search === 'function') {
    return;
  }
  
  if (window.pagefindLoading) return;
  window.pagefindLoading = true;

  try {
    const pagefind = await import(scriptUrl);
    await pagefind.options({ excerptLength: 20 });
    window.pagefind = pagefind;
    document.dispatchEvent(new CustomEvent('pagefind-ready'));
  } catch (error) {
    console.error('Pagefind load failed:', error);
  } finally {
    window.pagefindLoading = false;
  }
}

function attachSearchListener() {
  const btn = document.getElementById('search-button');
  if (btn) {
    btn.addEventListener('click', loadAndSearch, { once: true });
  }
}

document.addEventListener('astro:page-load', attachSearchListener);
</script>
}
