---
import "@styles/global.css"

import type { CollectionEntry } from 'astro:content';
import { render } from 'astro:content'

import { getRelativeLocaleUrl } from '@utils/url-utils';
import { formatFullDate } from '@/utils/time'

import { i18n } from "astro:config/client";
import i18nit from '@i18n/translation'
import { Icon } from "astro-icon/components";

interface Props {
    entry: CollectionEntry<'blog'>;
    title: string;
    description: string;
    image: string;
    pubDate: Date;
    url: string;
    fallback: boolean;
}

const { entry, title, description, image, pubDate, url, fallback } = Astro.props;

const currentLang = Astro.currentLocale || i18n!.defaultLocale;
const t = i18nit(currentLang);

const pageUrl = getRelativeLocaleUrl(currentLang, "/blog/" + url);
const { remarkPluginFrontmatter } = await render(entry);
---

<div data-aos="fade-up" class="blog-post-item">
  <span class="blog-post-date">{formatFullDate(pubDate, currentLang)}</span>
  <div class="blog-post-content">
    <a href={pageUrl} class="blog-post-title">
      {entry.data.pinTop > 0 && <Icon name="fluent:pin-24-filled" class="pin-icon" />}
      {title}
    </a>
    {fallback && <span class="fallback-badge">{i18n!.defaultLocale}</span>}
    {description && <p class="blog-post-desc">{description}</p>}
  </div>
</div>

<style is:global>
.blog-post-item {
  display: flex;
  align-items: baseline;
  gap: 1.2em;
  padding: 0.4em 0;
  border-bottom: 1px solid var(--hairline);
}
.blog-post-item:last-child {
  border-bottom: none;
}
.blog-post-date {
  flex-shrink: 0;
  min-width: 6.5em;
  font-size: 0.85rem;
  color: var(--text-color-70);
  font-variant-numeric: tabular-nums;
}
.blog-post-content {
  flex: 1;
  min-width: 0;
}
.blog-post-title {
  color: var(--text-color);
  text-decoration: none;
  font-size: 1.05rem;
  transition: color 0.2s ease;
}
.blog-post-title:hover {
  color: var(--link-color);
}
.pin-icon {
  display: inline;
  margin-right: 0.25em;
  width: 0.85em;
  height: 0.85em;
  color: var(--link-color);
}
.fallback-badge {
  display: inline-block;
  font-size: 0.75rem;
  color: var(--text-color-70);
  font-family: monospace;
  text-transform: uppercase;
  background: var(--code-bg);
  padding: 0.1em 0.4em;
  border-radius: 3px;
  margin-left: 0.5em;
  border: 1px solid var(--hairline);
}
.blog-post-desc {
  margin: 0.2em 0 0;
  font-size: 0.85rem;
  color: var(--text-color-70);
  line-height: 1.5;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}
@media (max-width: 600px) {
  .blog-post-item {
    flex-direction: column;
    gap: 0.1em;
    padding: 0.6em 0;
  }
}
</style>
