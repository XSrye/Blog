---
import '@styles/global.css'
import { siteConfig, profileConfig } from '@/config'
import MainPageLayout from '@layouts/MainPageLayout.astro'
import Markdown from '@components/misc/Markdown.astro'
import ImageModule from '@components/misc/ImageModule.astro'
import FabMenu from '@components/control/FabMenu.astro'
import TOC from '@components/TOC.svelte'
import BlogNavi from '@components/control/BlogNavi.astro'

import { render } from 'astro:content'
import { i18n } from "astro:config/client";
import i18nit from '@i18n/translation'


import { blogCoverUrl } from '@/utils/url-utils'
import { formatFullDate } from '@/utils/time'
import { getBlogEntrySort } from '@utils/content-utils'
import { getRelativeLocaleUrl } from '@utils/url-utils';


const currentLang = Astro.currentLocale || i18n!.defaultLocale;
const t = i18nit(currentLang);

export async function getStaticPaths() {
    
    // 获取所有支持的语言
    const locales = i18n?.locales || [i18n?.defaultLocale];
    
    // 为每种语言和每篇文章组合生成路由
    const paths = [];
    
    for (const locale of locales) {
        const blogEntries = await getBlogEntrySort(locale);

        for (let i = 0; i < blogEntries.length; i++) {
            const entry = blogEntries[i];
            const next = i > 0 ? blogEntries[i - 1] : null;
            const prev = i < blogEntries.length - 1 ? blogEntries[i + 1] : null;

            paths.push({
                params: {
                    locale: locale === i18n?.defaultLocale ? undefined : locale,
                    id: entry.id
                },
                props: { 
                    entry,
                    prev,
                    next
                }
            });
        }
    }
    
    return paths;
}
const { entry, prev, next } = Astro.props;
const { Content, headings } = await render(entry); // 获取渲染后的正文内容

const pageTitle = entry.data.title + ' - ' + siteConfig.title;
const image = blogCoverUrl(entry.data.image, entry.id);

const { remarkPluginFrontmatter } = await render(entry);
---
<MainPageLayout title={pageTitle} lang={currentLang} description={entry.data.description}>
    <div class="mx-auto w-full max-w-[var(--page-width)] py-6">
        <div class="mb-10 text-center">
            <h1 class="font-bold text-2xl mb-3 text-[var(--text-color)]" style="line-height: 1.5;">{ entry.data.title }</h1>
            <time class="block text-[var(--text-color-70)]" style="font-size: 0.85rem; letter-spacing: 0.03em;">{ formatFullDate(entry.data.pubDate, currentLang) }</time>
            <div class="mt-2 text-sm text-[var(--text-color-70)]">{profileConfig.name}</div>
            <div class="flex justify-center mt-3">
                <div class="flex flex-wrap items-center justify-center text-xs text-[var(--text-color-70)] gap-3">
                    <span>{remarkPluginFrontmatter.words || 0} {t("pagecard.words")}</span>
                    <span>&middot;</span>
                    <span>{remarkPluginFrontmatter.minutes || 0} {t("pagecard.minutes")}</span>
                    {entry.data.category && <>
                        <span>&middot;</span>
                        <a href={getRelativeLocaleUrl(currentLang, `/archives/?category=${entry.data.category}`)} class="hover:text-[var(--link-color)] transition-colors">{entry.data.category}</a>
                    </>}
                </div>
            </div>
        </div>
        {image && (
            <div class="mb-8">
                <ImageModule src={image} class="w-full h-full object-cover" style="border-radius: 2px;"/>
            </div>
        )}
        {entry.data.draft && (
        <div class="my-8 flex items-start gap-3 rounded-lg border border-[var(--danger-border-color)] bg-[var(--danger-bg-color)] p-4 text-sm text-[var(--danger-text-color)] transition-colors">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="mt-0.5 shrink-0 opacity-80">
                <path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"/>
                <line x1="12" y1="9" x2="12" y2="13"/>
                <line x1="12" y1="17" x2="12.01" y2="17"/>
            </svg>
            
            <div>
                <p class="leading-relaxed">
                    <span class="font-semibold">{t("draftNote.warning")}</span>
                    {t("draftNote.description")}
                </p>
            </div>
        </div>
        )}
        {entry.isFallback && (
        <div class="my-8 flex items-start gap-3 rounded-lg border border-[var(--warning-border-color)] bg-[var(--warning-bg-color)] p-4 text-sm text-[var(--warning-text-color)] transition-colors">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="mt-0.5 shrink-0 opacity-80">
            <circle cx="12" cy="12" r="10"/><path d="M12 16v-4"/><path d="M12 8h.01"/>
            </svg>
            
            <div>
            <p class="leading-relaxed">
                <span class="font-semibold">{t("langNote.note")}</span> 
                {t("langNote.description")}
            </p>
            </div>
        </div>
        )}
        <Markdown class="mb-6 mt-10 markdown-content">
            <Content />
        </Markdown>
        {
            siteConfig.blogNavi.enable &&
            <BlogNavi prev={prev} next={next}/>
        }

    </div>
    {
        siteConfig.toc.enable &&
        <TOC headings={headings} language={currentLang} client:load/>
    }
    <FabMenu headings={headings} showComment={siteConfig.comments.enable} showBackBottom={!siteConfig.comments.enable}/>
</MainPageLayout>